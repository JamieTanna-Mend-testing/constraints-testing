{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended"
	],
	"branchConcurrentLimit": 100,
	"prConcurrentLimit": 100,
	"prHourlyLimit": 100,
	"constraints": {
		"uv": "1.0.*",
		"go": "1.25.1",
		"golang": "1.25.9",
		"npm": "^5.0.0",
		"php": ">=8.2 <8.3"
	},
	"packageRules": [
		{
			"matchDepTypes": [
				"tool-constraint"
			],
			"separateMajorMinor": true,
			"separateMultipleMajor": true,
			"separateMultipleMinor": true,
			"separateMinorPatch": true
		},
		{
			"matchFileNames": [
				"go.mod"
			],
			"constraints": {
				"golang": "1.20"
			}
		}
	]
}
